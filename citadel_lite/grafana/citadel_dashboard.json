{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pipeline Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(citadel_pipeline_runs_total[5m])",
          "legendFormat": "{{event_type}} / {{outcome}}"
        }
      ],
      "title": "Pipeline Runs (rate/5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "expr": "citadel_pipelines_in_flight",
          "legendFormat": "In-Flight"
        }
      ],
      "title": "Pipelines In-Flight",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(citadel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(citadel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(citadel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Pipeline Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "title": "Agent Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(citadel_agent_runs_total[5m])",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "title": "Agent Invocations (rate/5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 101 },
              { "color": "yellow", "value": 501 },
              { "color": "green", "value": 2001 },
              { "color": "blue", "value": 10001 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "expr": "citadel_agent_xp",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "title": "Agent XP",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "D" } }, "type": "value" },
            { "options": { "1": { "text": "C" } }, "type": "value" },
            { "options": { "2": { "text": "B" } }, "type": "value" },
            { "options": { "3": { "text": "A" } }, "type": "value" },
            { "options": { "4": { "text": "S" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 },
              { "color": "blue", "value": 4 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "citadel_agent_grade",
          "legendFormat": "{{agent_id}}",
          "format": "table",
          "instant": true
        }
      ],
      "title": "Agent CAPS Grade",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "Governance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "options": { "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "citadel_ags_verdicts_total",
          "legendFormat": "{{verdict}}"
        }
      ],
      "title": "AGS Verdicts",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(citadel_risk_scores_bucket[5m]))",
          "legendFormat": "Median Risk"
        },
        {
          "expr": "histogram_quantile(0.90, rate(citadel_risk_scores_bucket[5m]))",
          "legendFormat": "p90 Risk"
        }
      ],
      "title": "Risk Score Distribution",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 9,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_sparkline" },
      "targets": [
        {
          "expr": "increase(citadel_verify_retries_total[1h])",
          "legendFormat": "Retries (1h)"
        }
      ],
      "title": "Verify Retries (1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 400,
      "title": "Auto-Merge",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(citadel_auto_merge_total[5m])",
          "legendFormat": "{{result}}"
        }
      ],
      "title": "Auto-Merge Results (rate/5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "citadel_agent_tp",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "title": "Agent TP (Treasury Points)",
      "type": "bargauge"
    }
  ],
  "schemaVersion": 39,
  "tags": ["citadel", "devops", "agents", "agentic-devops"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Citadel Lite Pipeline",
  "uid": "citadel-lite-pipeline",
  "version": 1
}
