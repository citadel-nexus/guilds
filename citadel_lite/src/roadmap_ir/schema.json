{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://citadel-lite.local/schemas/roadmap_ir.schema.json",
  "title": "Citadel Lite Roadmap IR",
  "description": "Intermediate JSON format (Roadmap IR) that all roadmap inputs are translated into. Deterministic and evidence-first.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "generated_at",
    "sources",
    "catalog",
    "items",
    "metrics",
    "conflicts",
    "notes"
  ],
  "properties": {
    "schema": {
      "const": "citadel.roadmap_ir"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Source"
      }
    },
    "catalog": {
      "$ref": "#/$defs/Catalog"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Item"
      },
      "uniqueItems": false
    },
    "metrics": {
      "$ref": "#/$defs/Metrics"
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Conflict"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Note"
      }
    }
  },
  "$defs": {
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "type",
        "label",
        "fingerprint",
        "collected_at"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
        },
        "type": {
          "type": "string",
          "enum": ["markdown", "plaintext", "gitlog", "json", "other"]
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^(sha256):[0-9a-f]{64}$"
        },
        "path_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "collected_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_enum", "verify_enum", "revenue_gates"],
      "properties": {
        "status_enum": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["unknown", "planned", "in_progress", "blocked", "done"]
          },
          "minItems": 5,
          "maxItems": 5
        },
        "verify_enum": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["unknown", "not_tested", "tested", "verified"]
          },
          "minItems": 4,
          "maxItems": 4
        },
        "revenue_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tradebuilder",
              "zes_agent",
              "platform_saas",
              "data_products",
              "upsell",
              "unknown"
            ]
          },
          "minItems": 6,
          "maxItems": 6
        }
      }
    },
    "Metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commit_velocity": {
          "$ref": "#/$defs/CommitVelocity"
        },
        "phase_completion": {
          "$ref": "#/$defs/PhaseCompletion"
        },
        "generated_warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400
          }
        }
      }
    },
    "CommitVelocity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_days", "commits_total", "commits_by_day"],
      "properties": {
        "window_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "commits_total": {
          "type": "integer",
          "minimum": 0
        },
        "commits_by_day": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["date", "count"],
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "PhaseCompletion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["done", "in_progress", "blocked", "planned", "unknown"],
      "properties": {
        "done": { "type": "integer", "minimum": 0 },
        "in_progress": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "planned": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 }
      }
    },
    "Item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "kind", "title", "status", "evidence"],
      "properties": {
        "item_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$"
        },
        "kind": {
          "type": "string",
          "enum": ["phase", "feature", "milestone", "task"]
        },
        "phase": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 999
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "status": {
          "type": "string",
          "enum": ["unknown", "planned", "in_progress", "blocked", "done"]
        },
        "verify_status": {
          "type": "string",
          "enum": ["unknown", "not_tested", "tested", "verified"],
          "default": "unknown"
        },
        "readiness": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "revenue_gate": {
          "type": "string",
          "enum": [
            "tradebuilder",
            "zes_agent",
            "platform_saas",
            "data_products",
            "upsell",
            "unknown"
          ],
          "default": "unknown"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$"
          }
        },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/Blocker" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/Output" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Evidence" }
        },
        "raw": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "confidence"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "Output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["endpoint", "module", "path", "command", "artifact", "doc", "test"]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "extra": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Evidence": {
      "oneOf": [
        { "$ref": "#/$defs/EvidenceFileLoc" },
        { "$ref": "#/$defs/EvidenceGit" },
        { "$ref": "#/$defs/EvidenceText" }
      ]
    },
    "EvidenceFileLoc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "loc", "weight"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
        },
        "loc": { "$ref": "#/$defs/Loc" },
        "quote": {
          "type": "string",
          "minLength": 0,
          "maxLength": 800
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "Loc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line_start", "line_end"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "EvidenceGit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "commit", "weight"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string",
          "minLength": 0,
          "maxLength": 200
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "message": {
          "type": "string",
          "minLength": 0,
          "maxLength": 500
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "EvidenceText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "text", "weight"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "Conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "field", "values", "resolution", "action_hint"],
      "properties": {
        "item_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$"
        },
        "field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "values": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "value"],
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
              },
              "value": {}
            }
          }
        },
        "resolution": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "action_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    },
    "Note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "message"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{1,63}$"
        },
        "item_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$"
        }
      }
    }
  }
}
